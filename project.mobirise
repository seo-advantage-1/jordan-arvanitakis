            },
            ".title-wrapper": {
              ".mbr-section-title": {
                "display": "inline-block",
                "width": "80%",
                "margin-bottom": "40px",
                "@media (max-width: 992px)": {
                  "width": "100%",
                  "margin-bottom": "16px"
                }
              }
            },
            ".items-wrapper": {
              ".item": {
                ".item-wrapper": {
                  ".item-content": {
                    "position": "relative",
                    "display": "flex",
                    "align-items": "flex-end",
                    "justify-content": "space-between",
                    "padding": "64px 0 16px 0",
                    "@media (max-width: 992px)": {
                      "display": "block",
                      "padding": "24px 0 16px 0"
                    },
                    "& when (@showBorder)": {
                      "border-bottom": "1px solid @border",
                      "&::before": {
                        "content": "''",
                        "position": "absolute",
                        "bottom": "-1px",
                        "right": "-20px",
                        "width": "20px",
                        "height": "1px",
                        "background-color": "@border",
                        "@media (max-width: 992px)": {
                          "right": "-16px",
                          "width": "16px"
                        },
                        "& when (@reverseContent)": {
                          "right": "auto",
                          "left": "-20px",
                          "@media (max-width: 992px)": {
                            "left": "auto",
                            "right": "-16px"
                          }
                        }
                      },
                      "@media (max-width: 992px)": {
                        "&::after": {
                          "content": "''",
                          "position": "absolute",
                          "bottom": "-1px",
                          "left": "-16px",
                          "width": "16px",
                          "height": "1px",
                          "background-color": "@border"
                        }
                      }
                    },
                    ".item-title": {
                      "margin-bottom": "0",
                      "width": "50%",
                      "@media (max-width: 992px)": {
                        "width": "100%",
                        "margin-bottom": "16px"
                      }
                    },
                    ".item-number": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#0a0a0a"
            },
            ".item-title": {
              "color": "#0a0a0a"

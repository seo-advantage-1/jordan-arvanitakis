          "_name": "pricing02",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"pricing02 capturem5\" group=\"Pricing\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\">\n        <input type=\"checkbox\" title=\"Price\" name=\"showPrice\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"BG\" value=\"#252525\" name=\"cardBg\" selected>\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#404040\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#0a0a0a\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap row justify-content-between title-wrapper\" mbr-if=\"showTitle || showLabel\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 item\">\n                            <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">Pets</h2>\n                        </div>\n                    </div>\n                    <div class=\"content-wrap row justify-content-center\">\n                        <div class=\"col-12 col-lg-4 item features-image\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/border-collie.png-730x913.png\" alt=\"image of a border collie\">\n                                </div>\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title\">\n                                        Starter Portfolio\n                                    </h4>\n                                    <p class=\"item-price mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showPrice\" data-app-selector=\".item-price\">\n                                        $200\n                                    </p>\n                                    <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text\">\n                                        It includes a portfolio review, guidance on selecting up to 10\n                                        artworks, and a simple digital layout to present your work professionally.\n                                    </p>\n                                </div>\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Get In Touch</a></div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-4 item features-image\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/ginger-cat.png-730x913.png\" alt=\"image of a ginger cat\">\n                                </div>\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title\">\n                                        Professional Portfolio\n                                    </h4>\n                                    <p class=\"item-price mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showPrice\" data-app-selector=\".item-price\">\n                                        $500\n                                    </p>\n                                    <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text\">\n                                        This package offers consultation, selection of up to 20 artworks, custom layout\n                                        and storytelling, and both digital.\n                                    </p>\n                                </div>\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\"><a class=\"btn btn-white\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                        GET IN TOUCH\n                                    </a></div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-4 item features-image\">\n                            <div class=\"item-wrapper\">\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/golden-retriever.png-730x913.png\" alt=\"image of a german shephard\">\n                                </div>\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title\">\n                                        Master Portfolio\n                                    </h4>\n                                    <p class=\"item-price mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showPrice\" data-app-selector=\".item-price\">\n                                        $800\n                                    </p>\n                                    <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text\">\n                                        It includes in-depth consultation, selection of up to 30 artworks, advanced\n                                        layout and design, interactive and print-ready versions.\n                                    </p>\n                                </div>\n                                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd\"><a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                        GET IN TOUCH\n                                    </a></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_anchor": "pricing02-4",
          "_cid": "vgOLtZz6Tv",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden"
            },
            ".content-wrapper": {
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "flex-direction": "column",
                "justify-content": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              }
            },
            ".content-wrap": {
              "width": "-webkit-fill-available",
              "margin": "0 -4px"
            },
            ".card": {
              "padding": "0 8px"
            },
            ".card-wrapper": {
              "height": "100%",
              "padding": "24px 20px",
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "space-between",
              "position": "relative",
              "min-height": "435px",
              "@media (max-width: 992px)": {
                "min-height": "350px",
                "padding": "24px 16px"
              },
              ".image-wrapper": {
                "img": {
                  "position": "absolute",
                  "top": "0",
                  "left": "0",
                  "width": "100%",
                  "height": "100%",
                  "object-fit": "cover"
                }
              },
              "&::before": {
                "content": "''",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-image": "linear-gradient(180deg, transparent 0, @cardGradient 100%)",
                "pointer-events": "none",
                "z-index": "1"
              },
              ".label-wrapper": {
                "position": "relative",
                "z-index": "1",
                ".mbr-label": {
                  "display": "inline-flex",
                  "padding": "2px 6px",
                  "background-color": "@labelBg",
                  "margin-bottom": "24px"
                }
              },
              ".title-wrapper": {
                "position": "relative",
                "z-index": "1",
                ".title-wrap": {
                  ".mbr-section-title": {
                    "display": "inline-block",
                    "width": "70%",
                    "margin-bottom": "0",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    }
                  }
                },
                ".mbr-section-btn": {
                  "margin-top": "16px"
                }
              }
            },
            ".embla__slide": {
              "display": "flex",
              "justify-content": "center",
              "position": "relative",
              "min-width": "100%",
              "max-width": "100%",
              "@media (max-width: 768px)": {
                "min-width": "100%",
                "max-width": "100%",
                "margin-left": "1rem !important",
                "margin-right": "1rem !important"
              },
              ".slide-content": {
                "width": "100%",
                ".item-wrapper": {
                  "display": "flex",
                  "flex-direction": "column",
                  "justify-content": "space-between",
                  "height": "100%",
                  "padding": "24px 20px",
                  "background-color": "@cardBg",
                  "@media (max-width: 992px)": {
                    "padding": "24px 16px",
                    "& when (@arrows)": {
                      "padding-bottom": "52px"
                    }
                  },
                  ".text-wrapper": {
                    "position": "relative",
                    "z-index": "1",
                    ".item-text": {
                      "display": "inline-block",
                      "width": "80%",
                      "margin-bottom": "24px",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".person-wrapper": {
                    "position": "relative",
                    "z-index": "1",
                    ".person-wrap": {
                      "display": "inline-flex",
                      "align-items": "center",
                      ".item-img": {
                        "margin-right": "16px",
                        "img": {
                          "display": "inline-flex",
                          "width": "45px",
                          "height": "55px",
                          "min-width": "45px",
                          "object-fit": "cover"
                        }
                      },
                      ".name-wrap": {
                        ".item-name": {
                          "margin-bottom": "0"
                        },
                        ".item-role": {
                          "margin-bottom": "0"
                        }
                      }
                    }
                  }
                }
              }
            },
            ".embla__button--next, .embla__button--prev": {
              "display": "flex"
            },
            ".embla__button": {
              "bottom": "40px",
              "width": "28px",
              "height": "28px",
              "font-size": "16px",
              "background-color": "@arrowsBg !important",
              "color": "@arrowsColor !important",
              "border": "none !important",
              "transition": "all 0.3s",
              "position": "absolute",
              "display": "flex",
              "justify-content": "center",
              "align-items": "center",
              "opacity": "1 !important",
              "& when not (@arrows)": {
                "display": "none"
              },
              "& when not (@arrowsMobile)": {
                "@media (max-width: 768px)": {
                  "display": "none"
                }
              },
              "@media (max-width: 992px)": {
                "bottom": "16px"
              },
              "&:disabled": {
                "opacity": ".5 !important"
              },
              "&.embla__button--prev": {
                "right": "56px",
                "@media (max-width: 992px)": {
                  "right": "52px"
                }
              },
              "&.embla__button--next": {
                "right": "20px",
                "@media (max-width: 992px)": {
                  "right": "16px"
                }
              }
            },
            ".embla": {
              "position": "relative",
              "width": "100%",
              "height": "100%"
            },
            ".embla__viewport": {
              "position": "relative",
              "overflow": "hidden",
              "width": "100%",
              "padding": "0",
              "height": "100%",
              "@media (max-width: 768px)": {
                "padding": "0"
              }
            },
            ".embla__viewport.is-draggable": {
              "cursor": "grab"
            },
            ".embla__viewport.is-dragging": {
              "cursor": "grabbing"
            },
            ".embla__container": {
              "display": "flex",
              "user-select": "none",
              "-webkit-touch-callout": "none",
              "-khtml-user-select": "none",
              "-webkit-tap-highlight-color": "transparent",
              "height": "100%"
            },
            ".item-menu-overlay": {
              "opacity": "0 !important"
            },
            ".mbr-label": {
              "color": "#ffffff"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".item-text": {
              "color": "#0a0a0a"
            },
            ".item-name": {
              "color": "#0a0a0a"
            },
            ".item-role": {
              "color": "#909090"
            }
          },
          "_name": "slider01",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider01 mbr-embla capturem5\" group=\"Sliders & Galleries\" plugins=\"embla\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"color\" title=\"Label BG\" value=\"#ff4306\" name=\"labelBg\" condition=\"showLabel\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"Gradient Color\" value=\"#0a0a0a\" name=\"cardGradient\" selected>\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\">\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"1\" max=\"10\" value=\"2\" step=\"1\" condition=\"autoplay\">\n        <input type=\"checkbox\" title=\"Loop\" name=\"loop\">\n        <input type=\"checkbox\" title=\"Draggable\" name=\"draggable\" checked>\n        <input type=\"checkbox\" name=\"arrows\" title=\"Arrows\" checked>\n        <input type=\"checkbox\" name=\"arrowsMobile\" title=\"Mobile Arrows\" condition=\"arrows\" checked>\n        <input type=\"color\" name=\"arrowsColor\" title=\"Arrows Color\" value=\"#0a0a0a\" condition=\"arrows\">\n        <input type=\"color\" name=\"arrowsBg\" title=\"Arrows BG\" value=\"#ffffff\" condition=\"arrows\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Name\" name=\"showName\" checked>\n        <input type=\"checkbox\" title=\"Role\" name=\"showRole\" checked>\n        <input type=\"color\" title=\"BG\" value=\"#f8f8f8\" name=\"cardBg\" selected>\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#eaeaea\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f1f5eb\" condition=\"overlay && bg.type == 'image'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type == 'image'\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\" mbr-if=\"overlay && bg.type !== 'color'\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-6 card\">\n                            <div class=\"card-wrapper\">\n                                <div class=\"label-wrapper\">\n                                    <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label, .label-wrapper\" mbr-theme-style=\"display-4\" mbr-if=\"showLabel\">\n                                        Client Testimonials\n                                    </p>\n                                </div>\n                                <div class=\"image-wrapper\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/deer.png-960x1200.png\" alt=\"image of two deers\">\n                                </div>\n                                <div class=\"title-wrapper\">\n                                    <div class=\"title-wrap\">\n                                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .title-wrap, .mbr-section-btn\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">\n                                            What Artists Say About Working With Me\n                                        </h2>\n                                    </div>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            Leave a Review\n                                        </a>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6 card\">\n                            <div class=\"embla\" data-loop=\"{{loop}}\" data-auto-play=\"{{autoplay}}\" data-auto-play-interval=\"{{interval}}\" data-draggable=\"{{draggable}}\" data-skip-snaps=\"true\" data-align=\"center\" data-contain-scroll=\"trimSnaps\">\n                                <div class=\"embla__viewport\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n                                    <div class=\"embla__container\">\n                                        <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                            <div class=\"slide-content\">\n                                                <div class=\"item-wrapper\">\n                                                    <div class=\"text-wrapper\">\n                                                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-text, .text-wrapper\">\n                                                            \"The artwork completely changed the feel of my space. It’s the first thing people notice when they walk in.\"\n                                                        </p>\n                                                    </div>\n                                                    <div class=\"person-wrapper\">\n                                                        <div class=\"person-wrap\">\n                                                            <div class=\"item-img\">\n                                                                <img src=\"@PROJECT_PATH@/assets/images/mbr-90x90.png\" alt=\"Mobirise Website Builder\">\n                                                            </div>\n                                                            <div class=\"name-wrap\" mbr-if=\"showName || showRole\">\n                                                                <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name\">\n                                                                    James Hunt\n                                                                </p>\n                                                                <p class=\"item-role mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showRole\" data-app-selector=\".item-role\">\n                                                                    Interior Design Client\n                                                                </p>\n                                                            </div>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                            <div class=\"slide-content\">\n                                                <div class=\"item-wrapper\">\n                                                    <div class=\"text-wrapper\">\n                                                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-text, .text-wrapper\">\n                                                            \"High-quality and incredibly detailed. You can tell real care went into these pieces.\"\n                                                        </p>\n                                                    </div>\n                                                    <div class=\"person-wrapper\">\n                                                        <div class=\"person-wrap\">\n                                                            <div class=\"item-img\">\n                                                                <img src=\"@PROJECT_PATH@/assets/images/mbr-90x90.png\" alt>\n                                                            </div>\n                                                            <div class=\"name-wrap\" mbr-if=\"showName || showRole\">\n                                                                <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name\">\n                                                                    Ryan</p>\n                                                                <p class=\"item-role mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showRole\" data-app-selector=\".item-role\">\n                                                                    Digital Art Buyer\n                                                                </p>\n                                                            </div>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                        <div class=\"embla__slide slider-image item\" mbr-style=\"{'margin-left': gap + 'px', 'margin-right': gap + 'px'}\">\n                                            <div class=\"slide-content\">\n                                                <div class=\"item-wrapper\">\n                                                    <div class=\"text-wrapper\">\n                                                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".item-text, .text-wrapper\">\n                                                            \"I was looking for something unique that didn’t feel mass-produced, and this artwork delivered exactly that. The detail and colour are incredible; it’s added so much character to my home office.\"\n                                                        </p>\n                                                    </div>\n                                                    <div class=\"person-wrapper\">\n                                                        <div class=\"person-wrap\">\n                                                            <div class=\"item-img\">\n                                                                <img src=\"@PROJECT_PATH@/assets/images/mbr-90x90.png\" alt>\n                                                            </div>\n                                                            <div class=\"name-wrap\" mbr-if=\"showName || showRole\">\n                                                                <p class=\"item-name mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showName\" data-app-selector=\".item-name\">\n                                                                    Ming&nbsp;</p>\n                                                                <p class=\"item-role mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showRole\" data-app-selector=\".item-role\">\n                                                                    Interior Designer</p>\n                                                            </div>\n                                                        </div>\n                                                    </div>\n                                                </div>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                                <button class=\"embla__button embla__button--prev\">\n                                    <span class=\"mobi-mbri mobi-mbri-left mbr-iconfont\" aria-hidden=\"true\"></span>\n                                    <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Previous</span>\n                                </button>\n                                <button class=\"embla__button embla__button--next\">\n                                    <span class=\"mobi-mbri mobi-mbri-right mbr-iconfont\" aria-hidden=\"true\"></span>\n                                    <span class=\"sr-only visually-hidden visually-hidden visually-hidden\">Next</span>\n                                </button>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uZd8h9ROF5",
          "_anchor": "slider01-d",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },

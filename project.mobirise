              "position": "relative",
              "&::before, &::after": {
                "content": "''",
                "position": "absolute",
                "left": "0",
                "width": "100%",
                "height": "1px",
                "background-color": "@border"
              },
              "&::before": {
                "top": "0"
              },
              "&::after": {
                "bottom": "0"
              }
            },
            ".content-wrapper": {
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "align-items": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              },
              ".content-wrap": {
                ".mbr-section-title": {
                  "margin-bottom": "32px"
                },
                ".text-wrapper": {
                  ".mbr-text": {
                    "display": "inline-block",
                    "width": "50%",
                    "margin-bottom": "0",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    }
                  }
                },
                ".mbr-section-btn": {
                  "margin-top": "24px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#0a0a0a"
            },
            ".mbr-text": {
              "color": "#0a0a0a"
            }

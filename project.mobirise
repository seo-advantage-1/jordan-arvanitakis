                "display": "flex",
                "flex-direction": "column",
                "justify-content": "space-between",
                "overflow": "hidden",
                "background-color": "@cardBg",
                ".item-img": {
                  "padding": "20px 20px 40px 20px",
                  "@media (max-width: 992px)": {

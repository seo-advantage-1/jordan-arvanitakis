              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden"
            },
            ".content-wrapper": {
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "align-items": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              }
            },
            ".content-wrap": {
              "width": "-webkit-fill-available"
            },
            ".title-wrapper": {
              "margin-bottom": "40px"
            },
            ".mbr-label": {
              "margin-bottom": "24px",
              "color": "#0a0a0a"
            },
            ".mbr-section-title": {
              "margin-bottom": "24px",
              "color": "#0a0a0a"
            },
            ".text-wrapper": {
              ".mbr-text": {
                "display": "inline-block",
                "width": "85%",
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "width": "100%"
                }
              }
            },
            ".panel-group": {
              ".card": {
                "position": "relative",
                "padding": "16px",
                "background-color": "@cardBg",
                "border": "none",
                "margin-top": "16px",
                "&:first-child": {
                  "margin-top": "0"
                },
                ".card-header": {
                  "background-color": "transparent",
                  "border": "none",
                  "border-radius": "0",
                  "padding": "0",
                  ".panel-title": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "align-items": "center",
                    "width": "100%",
                    ".panel-title-edit": {
                      "margin-bottom": "0",
                      "transition": "all 0.3s ease-in-out"
                    },
                    ".icon-wrapper": {
                      "width": "28px",
                      "height": "28px",
                      "min-width": "28px",
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "margin-left": "16px",
                      "transition": "all 0.3s ease-in-out",
                      ".mbr-iconfont": {
                        "font-size": "16px",
                        "transition": "all 0.3s ease-in-out",
                        "color": "@icon"
                      }
                    },
                    "&:not(.collapsed)": {
                      ".icon-wrapper": {
                        ".mbr-iconfont": {
                          "transform": "rotate(45deg)"
                        }
                      }
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "padding-top": "16px",
                    ".panel-text": {
                      "display": "inline-flex",
                      "width": "70%",
                      "margin-bottom": "0",
                      "@media (max-width: 1440px)": {
                        "width": "100%"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-text": {
              "color": "#0a0a0a"
            },
            ".panel-title-edit": {
              "color": "#0a0a0a"
            },
            ".panel-text": {
              "color": "#0a0a0a"
            }
          },
          "_name": "list02",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list01 capturem5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Label\" name=\"showLabel\" checked>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <header>List</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Cards</header>\n        <input type=\"color\" title=\"Icon Color\" value=\"#0a0a0a\" name=\"icon\" selected>\n        <input type=\"color\" title=\"BG\" value=\"#f8f8f8\" name=\"cardBg\" selected>\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#eaeaea\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-4\">\n                            <div class=\"title-wrapper\">\n                                <p class=\"mbr-label mbr-fonts-style\" data-app-selector=\".mbr-label\" mbr-theme-style=\"display-4\" mbr-if=\"showLabel\">\n                                    FAQ\n                                </p>\n                                <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">\n                                    Frequently Asked Questions</h2>\n                                <div class=\"text-wrapper\">\n                                    <p class=\"mbr-text mbr-fonts-style\" data-app-selector=\".mbr-text, .text-wrapper\" mbr-theme-style=\"display-7\" mbr-if=\"showText\">\n                                        Creating an Art Portfolio can feel overwhelming, but it doesn’t have to be.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-8\">\n                            <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                                <div class=\"card little-radius\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">What do I receive when I purchase artwork?</h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                You’ll receive a high-resolution digital file that can be downloaded instantly and used for printing or digital display.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 1\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">What sizes can I print the artwork in?</h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                Files are provided in high resolution, making them suitable for a range of print sizes from small frames to large wall pieces.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 2\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">Can I use the artwork commercially?</h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                Artwork is for personal use unless otherwise specified. Contact us for licensing options.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 3\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">How do I print the artwork?</h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                You can print at home, through a local print shop, or use online printing services for professional results.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 4\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">Do I need a physical frame?</h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                That’s up to you; artwork can be framed, mounted, or displayed digitally.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                                <div class=\"card little-radius\" mbr-if=\"cardAmount > 5\">\n                                    <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                        <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                            <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-title-edit\">\n                                                How often should I update my portfolio?\n                                            </h4>\n                                            <div class=\"icon-wrapper\">\n                                                <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                            </div>\n                                        </a>\n                                    </div>\n                                    <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                        <div class=\"panel-body\">\n                                            <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".panel-text, .panel-body\">\n                                                Regular updates are crucial. Remove older works that no longer reflect\n                                                your style, and add new pieces that showcase your current abilities and\n                                                creative direction.\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uZd8pcfJGj",
          "_anchor": "list02-g",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden",
              "position": "relative"
            },
            ".content-wrapper": {
              "position": "relative",
              "display": "flex",
              "justify-content": "center",
              ".border-wrap": {
                "content": "''",
                "position": "absolute",
                "width": "1000%",
                "height": "1px",
                "background-color": "@border"
              },
              ".border_1": {
                "top": "0"
              },
              ".border_2": {
                "bottom": "0"
              },
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "align-items": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              },
              ".main-wrap": {
                "padding-top": "32px",
                "padding-bottom": "100px",
                "@media (max-width: 992px)": {
                  "padding-top": "24px",
                  "padding-bottom": "24px"
                }
              },
              ".content-wrap": {
                "width": "-webkit-fill-available",
                ".mbr-section-title": {
                  "margin-bottom": "24px"
                },
                ".text-wrapper": {
                  ".mbr-text": {
                    "display": "inline-block",
                    "width": "60%",
                    "margin-bottom": "0",
                    "@media (max-width: 992px)": {
                      "width": "100%",
                      "margin-bottom": "24px"
                    }
                  }
                },
                ".mbr-section-btn": {
                  "@media (max-width: 992px)": {
                    "margin-bottom": "24px"
                  }
                },
                ".nav-wrapper": {
                  "display": "grid",
                  "grid-template-columns": "1fr 1fr 1fr",
                  "gap": "40px 16px",
                  "flex-wrap": "wrap",
                  "@media (max-width: 992px)": {
                    "gap": "24px"
                  },
                  "@media (max-width: 768px)": {
                    "grid-template-columns": "1fr 1fr"
                  },
                  ".nav-wrap": {
                    ".mbr-list-title": {
                      "margin-bottom": "20px",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "16px"
                      }
                    },
                    ".list": {
                      "padding": "0",
                      "margin": "0",
                      "list-style-type": "none",
                      ".item-wrap": {
                        "position": "relative",
                        "margin-bottom": "16px",
                        "transition": "all 0.3s ease-in-out",
                        "&:hover, &:focus": {
                          "opacity": ".5"
                        },
                        "&:last-child": {
                          "margin-bottom": "0"
                        }
                      }
                    }
                  }
                }
              }
            },
            ".mbr-copy": {
              "padding": "32px 0",
              "margin-bottom": "0",
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".mbr-list-title": {
              "color": "#909090"
            },
            ".list": {
              "color": "#ffffff"
            }
          },
          "_name": "footer01",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer01 capturem5\" group=\"Footer\" global once=\"footers\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\t<mbr-parameters>\n\t\t<header>Size</header>\n\t\t<input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\t\t<input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n\t\t<input type=\"checkbox\" title=\"Navigation\" name=\"showNav\" checked>\n\t\t<input type=\"checkbox\" title=\"Navigation Title\" name=\"showNavTitle\" condition=\"showNav\">\n\t\t<input type=\"range\" inline title=\"Navigation Amount\" name=\"listAmount\" min=\"1\" max=\"3\" step=\"1\" value=\"3\" condition=\"showNav\">\n\t\t<input type=\"checkbox\" title=\"Copyright\" name=\"showCopy\" checked>\n\t\t<header>Border</header>\n\t\t<input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n\t\t<input type=\"color\" title=\"Color\" value=\"#404040\" name=\"border\" condition=\"showBorder\" selected>\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#0a0a0a\" selected>\n\t\t</fieldset>\n\t\t<header condition=\"bg.type === 'video'\">Fallback Image</header>\n\t\t<input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n\t</mbr-parameters>\n\n\t<div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n\t<div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n\t\t<div class=\"row\">\n\t\t\t<div class=\"col-12\">\n\t\t\t\t<div class=\"content-wrapper\" mbr-if=\"showTitle || showText || showButtons || showNav\">\n\t\t\t\t\t<div class=\"border-wrap border_1\" mbr-if=\"showBorder\"></div>\n\t\t\t\t\t<div class=\"content-wrap row justify-content-center main-wrap\">\n\t\t\t\t\t\t<div class=\"col-12 col-lg-4\" mbr-if=\"showTitle || showText\">\n\t\t\t\t\t\t\t<h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">Jordan Arvanitakis</h2>\n\t\t\t\t\t\t\t<div class=\"text-wrapper\">\n\t\t\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">Jordan Arvanitakis is a digital artist capturing the beauty, character, and energy of animals through bold, expressive artwork for modern spaces.\n\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-12 col-lg-4\" mbr-if=\"showButtons\">\n\t\t\t\t\t\t\t<div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-white-outline\" href=\"index.html#header01-5\" data-app-placeholder=\"Type Text\">\n\t\t\t\t\t\t\t\t\tView Artwork</a></div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-12 col-lg-4\" mbr-if=\"showNav\">\n\t\t\t\t\t\t\t<div class=\"nav-wrapper\">\n\t\t\t\t\t\t\t\t<div class=\"nav-wrap\">\n\t\t\t\t\t\t\t\t\t<h4 class=\"mbr-list-title mbr-fonts-style\" data-app-selector=\".mbr-list-title\" mbr-theme-style=\"display-4\" mbr-if=\"showNavTitle\">\n\t\t\t\t\t\t\t\t\t\tPages\n\t\t\t\t\t\t\t\t\t</h4>\n\t\t\t\t\t\t\t\t\t<ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n\t\t\t\t\t\t\t\t\t\t<li class=\"item-wrap\"><a href=\"index.html\" class=\"text-primary\">Home</a></li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"item-wrap\"><a href=\"index.html#header02-6\" class=\"text-primary\">About</a></li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"item-wrap\"><a href=\"index.html#header01-5\" class=\"text-primary\">Gallery</a></li><li class=\"item-wrap\"><a href=\"index.html#slider01-d\" class=\"text-primary\">Testimonials</a></li>\n\t\t\t\t\t\t\t\t\t\t<li class=\"item-wrap\"><a href=\"index.html#list02-g\" class=\"text-primary\">FAQs</a></li>\n\t\t\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<div class=\"border-wrap border_2\" mbr-if=\"showBorder\"></div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"content-wrapper\">\n\t\t\t\t\t<div class=\"content-wrap row\">\n\t\t\t\t\t\t<div class=\"col-12\" mbr-if=\"showCopy\">\n\t\t\t\t\t\t\t<p class=\"mbr-copy mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-copy\">\n\t\t\t\t\t\t\t\t© Copyright 2026 Jordan Arvanitakis - All Rights Reserved\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
          "_cid": "uZd8r8mhJC",
          "_anchor": "footer01-i",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],

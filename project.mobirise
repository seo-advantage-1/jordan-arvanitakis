        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden"
            },
            ".content-wrapper": {
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "flex-direction": "column",
                "justify-content": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              }
            },
            ".content-wrap": {
              "width": "-webkit-fill-available",
              "margin": "0 -4px"
            },
            ".title-wrapper": {
              "margin-bottom": "40px",
              "align-items": "flex-end",
              ".item": {
                "margin-bottom": "0"
              }
            },
            ".mbr-section-title": {
              "margin-bottom": "0",
              "@media (max-width: 992px)": {
                "margin-bottom": "24px"
              },
              "color": "#0a0a0a"
            },
            ".mbr-text": {
              "margin-bottom": "0",
              "color": "#0a0a0a"
            },
            ".item": {
              "padding": "0 4px",
              "margin-bottom": "8px",
              "@media (max-width: 992px)": {
                "margin-bottom": "16px",
                "&:last-child": {
                  "margin-bottom": "0"
                }
              },
              ".item-wrapper": {
                "height": "100%",
                "padding": "24px 20px",
                "display": "flex",
                "flex-direction": "column",
                "justify-content": "space-between",
                "overflow": "hidden",
                "@media (max-width: 992px)": {
                  "padding": "24px 16px"
                },
                "&:hover, &:focus": {
                  ".item-img img": {
                    "transform": "scale(1.05)",
                    "@media (max-width: 992px)": {
                      "transform": "none"
                    }
                  }
                },
                ".item-content": {
                  ".item-title_1, .item-title_2": {
                    "margin-bottom": "24px"
                  },
                  ".item-text_1, .item-text_2": {
                    "margin-bottom": "0"
                  },
                  ".text-wrap_1": {
                    ".item-text_1": {
                      "display": "inline-block",
                      "width": "60%",
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".text-wrap_2": {
                    ".item-text_2": {
                      "display": "inline-block",
                      "width": "60%",
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "width": "100%"
                      }
                    }
                  },
                  ".mbr-section-btn": {
                    "margin-top": "24px"
                  }
                },
                ".item-img": {
                  "display": "flex",
                  "justify-content": "center",
                  "margin-top": "24px",
                  "margin-bottom": "-24px",
                  "img": {
                    "height": "300px",
                    "width": "80%",
                    "object-fit": "cover",
                    "transition": "all .3s ease",
                    "@media (max-width: 992px)": {
                      "width": "100%"
                    },
                    "@media (max-width: 768px)": {
                      "height": "250px"
                    }
                  }
                }
              },
              ".card_1": {
                "background-color": "@cardBg_1"
              },
              ".card_2": {
                "background-color": "@cardBg_2"
              }
            },
            ".item-title_1": {
              "color": "#ffffff"
            },
            ".item-title_2": {
              "color": "#0a0a0a"
            },
            ".item-text_1": {
              "color": "#ffffff"
            },
            ".item-text_2": {
              "color": "#0a0a0a"
            }
          },
          "_name": "features03",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features03 capturem5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showCardTitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showCardText\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"color\" title=\"BG 1\" value=\"#ff4306\" name=\"cardBg_1\" selected>\n        <input type=\"color\" title=\"BG 2\" value=\"#f8f8f8\" name=\"cardBg_2\" selected>\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#eaeaea\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap row justify-content-between title-wrapper\" mbr-if=\"showTitle || showText\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-6 item\">\n                            <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">Artwork That Brings Your Space to Life</h2>\n                        </div>\n                        <div class=\"col-12 col-lg-3 item\">\n                            <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                                All artworks are pre-designed and available as high-resolution digital downloads. Each piece is created for versatility, ideal for printing as wall art, framing, or using across digital spaces.\n                            </p>\n                        </div>\n                    </div>\n                    <div class=\"content-wrap row justify-content-center\">\n                        <div class=\"col-12 col-lg-3 item features-image\">\n                            <div class=\"item-wrapper card_1\">\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title_1, .mbr-section-btn\">\n                                        Quality Over Quantity\n                                    </h4>\n                                    <p class=\"item-text_1 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text_1\">\n                                        Include only your strongest, most refined works.\n                                    </p>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            View More\n                                        </a>\n                                    </div>\n                                </div>\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/wolf-2.png-425x531.png\" alt=\"image of a wolf\">\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6 item features-image\">\n                            <div class=\"item-wrapper card_2\">\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title_2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title_2\">King of The Jungle</h4>\n                                    <div class=\"text-wrap_2\">\n                                        <p class=\"item-text_2 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text_2, .text-wrap_2\">\n                                            Ensure your portfolio feels unified — through theme, color palette, or style.\n                                        </p>\n                                    </div>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-black-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            View More\n                                        </a>\n                                    </div>\n                                </div>\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/lion-3.png-928x1160.png\" alt=\"image of a lion\">\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-3 item features-image\">\n                            <div class=\"item-wrapper card_1\">\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title_1, .mbr-section-btn\">\n                                        Reveal Your Creative Process\n                                    </h4>\n                                    <p class=\"item-text_1 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text_1\">\n                                        Don’t be afraid to show sketches, drafts, or concept stages.\n                                    </p>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            View More\n                                        </a>\n                                    </div>\n                                </div>\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/yellow-crest.png-425x531.png\" alt=\"image of a yellow crest\">\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6 item features-image\">\n                            <div class=\"item-wrapper card_1\">\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title_1, .mbr-section-btn\">\n                                        Organize with Intention\n                                    </h4>\n                                    <div class=\"text-wrap_1\">\n                                        <p class=\"item-text_1 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text_1, .text-wrap_1\">\n                                            Start with a powerful piece, guide the viewer through your creative range.\n                                        </p>\n                                    </div>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            View More\n                                        </a>\n                                    </div>\n                                </div>\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/polar-bear.png-928x1160.png\" alt=\"image of a polar bear\">\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"col-12 col-lg-6 item features-image\">\n                            <div class=\"item-wrapper card_2\">\n                                <div class=\"item-content\">\n                                    <h4 class=\"item-title_2 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title_2\">\n                                        Keep It Updated and Professional\n                                    </h4>\n                                    <div class=\"text-wrap_2\">\n                                        <p class=\"item-text_2 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\" data-app-selector=\".item-text_2, .text-wrap_2\">\n                                            Regularly refresh your portfolio with new works and remove older ones.\n                                        </p>\n                                    </div>\n                                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                                        <a class=\"btn btn-black-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                            View More\n                                        </a>\n                                    </div>\n                                </div>\n                                <div class=\"item-img\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/elephant.png-928x1160.png\" alt=\"image of an elephant\">\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "uZd812lP8F",
          "_anchor": "features03-3",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@showBorder)": {
              "overflow": "hidden"
            },
            ".content-wrapper": {
              "& when (@showBorder)": {
                "position": "relative",
                "display": "flex",
                "align-items": "center",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                },
                "&::before, &::after": {
                  "content": "''",
                  "position": "absolute",
                  "width": "1px",
                  "height": "1000vh",
                  "background-color": "@border"
                },
                "&::before": {
                  "left": "0"
                },
                "&::after": {
                  "right": "0"
                }
              }
            },
            ".content-wrap": {
              "width": "-webkit-fill-available",
              "min-width": "-moz-available",
              "align-items": "center"
            },
            ".mbr-section-title": {
              "margin-bottom": "32px",
              "color": "#0a0a0a"
            },
            ".text-wrapper": {
              ".mbr-text": {
                "display": "inline-block",
                "width": "80%",
                "margin-bottom": "0",
                "@media (max-width: 992px)": {
                  "width": "100%"
                }
              }
            },
            ".mbr-section-btn": {
              "margin-top": "24px"
            },
            ".image-wrapper": {
              "position": "relative",
              "@media (max-width: 992px)": {
                "margin-top": "32px"
              },
              ".decor-wrap": {
                "display": "grid",
                "position": "absolute",
                "grid-template-rows": "repeat(3, 28px)",
                "grid-template-columns": "repeat(3, minmax(28px, 1fr))",
                "grid-auto-rows": "28px",
                "justify-content": "center",
                "gap": "0",
                "pointer-events": "none",
                "will-change": "transform",
                "animation": "none !important",
                ".item-decor": {
                  "width": "100%",
                  "height": "100%",
                  "background-color": "@bg-value",
                  "box-shadow": "0 -28px 0 @bg-value",
                  "transform": "none"
                },
                ".decor-opacity": {
                  "background-color": "transparent",
                  "box-shadow": "none"
                }
              },
              ".decor_1": {
                "top": "-1px",
                "left": "-1px"
              },
              ".decor_2": {
                "grid-template-rows": "none",
                "top": "-1px",
                "right": "-1px"
              },
              ".image-wrap": {
                "img": {
                  "height": "575px",
                  "width": "100%",
                  "object-fit": "cover",
                  "animation": "none",
                  "@media (max-width: 992px)": {
                    "height": "300px"
                  }
                }
              }
            },
            ".mbr-text": {
              "color": "#0a0a0a"
            },
            ".mbr-section-title, .mbr-section-btn, .title-wrapper": {
              "color": "#ffffff"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#ffffff"
            }
          },
          "_name": "header02",
          "_sourceTheme": "capturem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header02 capturem5\" group=\"Header\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Decor\" name=\"showDecor\" condition=\"bg.type == 'color'\" checked>\n        <header>Border</header>\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Color\" value=\"#eaeaea\" name=\"border\" condition=\"showBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#0a0a0a\" selected>\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n                        <div class=\"col-12 col-lg-7\">\n                            <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn, .title-wrapper\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">\n\t\t\t\t\t\t\t\tAbout</h2>\n                            <div class=\"text-wrapper\">\n                                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">Jordan Arvanitakis is a digital artist specialising in creating stylised, illustration-based artwork that emphasises colour, shape, and personality over realism. His work focuses on capturing character and expression, resulting in visually striking pieces that feel modern and distinctive.<br><br>He produces high-resolution digital artworks designed for prints, wall art, and interior styling, making it easy to bring bold, animal-inspired visuals into any space without the need for custom commissions.<br></p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"index.html#header01-5\" data-app-placeholder=\"Type Text\">View Artwork</a></div>\n                        </div>\n                        <div class=\"col-12 col-lg-5\">\n                            <div class=\"image-wrapper\">\n                                <div class=\"decor-wrap decor_1\" mbr-if=\"showDecor && bg.type == 'color'\">\n                                    <div class=\"item-decor\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                    <div class=\"item-decor\"></div>\n                                    <div class=\"item-decor\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                    <div class=\"item-decor shadow-none\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                </div>\n                                <div class=\"decor-wrap decor_2\" mbr-if=\"showDecor && bg.type == 'color'\">\n                                    <div class=\"item-decor\"></div>\n                                    <div class=\"item-decor decor-opacity\"></div>\n                                    <div class=\"item-decor\"></div>\n                                </div>\n                                <div class=\"image-wrap\">\n                                    <img src=\"@PROJECT_PATH@/assets/images/lion.png-960x1200.png\" alt=\"image of a lion\">\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",

                  },
                  ".item-title": {
                    "margin-bottom": "24px"
                  },
                  ".item-price": {
                    "margin-bottom": "24px"
                  },
                  ".item-text": {
                    "margin-bottom": "0"
                  }
                },
                ".mbr-section-btn": {
                  "width": "100%",
                  "margin-bottom": "40px",
                  "@media (max-width: 992px)": {
                    "margin-bottom": "24px"
                  },
                  ".btn": {
                    "width": "100%",
                    "margin-top": "0",
                    "padding": "22px 45px",
                    "@media (max-width: 992px)": {
